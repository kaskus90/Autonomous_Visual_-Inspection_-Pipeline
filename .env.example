# MQTT
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_TOPIC=inspections/line1/detections

# Inference
# Use "demo" for synthetic frames (no camera needed), "0" for webcam,
# or an absolute path inside the container for a video file.
VIDEO_SOURCE=demo
CONFIDENCE_THRESHOLD=0.4
CAPTURE_FPS=5

# Database
POSTGRES_USER=inspector
POSTGRES_PASSWORD=inspector_pass
POSTGRES_DB=inspections
DATABASE_URL=postgresql+asyncpg://inspector:inspector_pass@postgres:5432/inspections

# API
API_PORT=8000

# Alerts
ALERT_DEFECT_RATE_THRESHOLD=5
ALERT_WEBHOOK_URL=
