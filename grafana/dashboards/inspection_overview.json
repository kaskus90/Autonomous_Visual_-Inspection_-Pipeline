{
  "title": "Visual Inspection Overview",
  "uid": "inspection-overview",
  "version": 1,
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Defects per Minute",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 16, "h": 8 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT date_trunc('minute', timestamp) AS time, count(*) AS defects FROM detections WHERE $__timeFilter(timestamp) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      }
    },
    {
      "id": 2,
      "title": "Total Detections",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT count(*) AS total FROM detections WHERE $__timeFilter(timestamp)",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 100 }] } }
      }
    },
    {
      "id": 3,
      "title": "Avg Confidence",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT round(avg(confidence)::numeric, 3) AS avg_conf FROM detections WHERE $__timeFilter(timestamp)",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.8 }] } }
      }
    },
    {
      "id": 4,
      "title": "Defect Class Breakdown",
      "type": "piechart",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 8 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT class_name, count(*) AS count FROM detections WHERE $__timeFilter(timestamp) GROUP BY class_name ORDER BY count DESC LIMIT 10",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": { "pieType": "donut", "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "id": 5,
      "title": "Confidence Distribution",
      "type": "histogram",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT confidence FROM detections WHERE $__timeFilter(timestamp)",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "options": { "bucketSize": "auto", "fillOpacity": 80 }
    },
    {
      "id": 6,
      "title": "Alert History",
      "type": "table",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT fired_at AS \"Time\", line_id AS \"Line\", defect_count AS \"Defects\", threshold AS \"Threshold\" FROM alert_logs ORDER BY fired_at DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "Defects" }, "properties": [{ "id": "custom.displayMode", "value": "color-background" }, { "id": "thresholds", "value": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 5 }] } }] }
        ]
      }
    }
  ]
}
